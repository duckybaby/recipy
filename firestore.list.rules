// Firestore Security Rules for the `recipy-list` named database.
//
// `recipy-list` is the recipe library — every recipe Anthropic returns
// gets upserted here by the Cloud Function (via firebase-admin SDK,
// which bypasses these rules). Client code reads recipes to resolve
// saved-recipe references in the user's library.
//
// Read: any authenticated user. The recipe content itself is from public
// web pages with attribution — no privacy concern about the recipe data.
// Write: server-only. Clients never touch this database directly.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Everything else: closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
