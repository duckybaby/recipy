# Copy this file to .env.local and customise.
#
# .env.local is gitignored — that's where your *real* dev settings go.

# When true, the frontend short-circuits every /api/* call to canned mock
# data (see src/lib/mockApi.ts). Use this for UI work to avoid spending
# Anthropic credits. Flip to false (or remove the line) to hit production.
VITE_USE_MOCKS=true

# Optional. Override the API base URL — leave empty to use the same origin
# (which is what production uses via the Firebase Hosting /api/** rewrite).
# Set to e.g. http://localhost:5001 when running the Firebase emulator.
# VITE_API_BASE=
